<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8">
  <style>{{ css | safe }}</style>
  {% if katex_css %}<style>{{ katex_css | safe }}</style>{% endif %}
</head>
<body>
  <main>
    {{ answer_html | safe }}
  </main>
  <script>
    window.__FJKER_MATH_READY = false;
    window.__FJKER_MATH_DISABLED = false;
  </script>
  {% if katex_js %}<script>{{ katex_js | safe }}</script>{% endif %}
  {% if katex_js and katex_auto_render_js %}
  <script>{{ katex_auto_render_js | safe }}</script>
  <script>
    try {
      renderMathInElement(document.body, {
        delimiters: [
          {left: "$$", right: "$$", display: true},
          {left: "$", right: "$", display: false},
          {left: "\\(", right: "\\)", display: false},
          {left: "\\[", right: "\\]", display: true}
        ],
        throwOnError: false
      });
    } finally {
      window.__FJKER_MATH_READY = true;
    }
  </script>
  {% else %}
  <script>
    window.MathJax = {
      tex: {
        inlineMath: [["\\(", "\\)"], ["$", "$"]],
        displayMath: [["\\[", "\\]"], ["$$", "$$"]]
      },
      svg: {
        fontCache: "none"
      },
      startup: {
        pageReady: function () {
          return MathJax.startup.defaultPageReady()
            .then(function () { window.__FJKER_MATH_READY = true; })
            .catch(function (error) {
              window.__FJKER_MATH_ERROR = String(error);
              window.__FJKER_MATH_DISABLED = true;
            });
        }
      }
    };
  </script>
  {% if mathjax_src %}
  <script async src="{{ mathjax_src }}" onerror="window.__FJKER_MATH_ERROR = 'Local MathJax failed to load'; window.__FJKER_MATH_DISABLED = true;"></script>
  {% else %}
  <script>
    window.__FJKER_MATH_ERROR = "Local MathJax asset missing";
    window.__FJKER_MATH_DISABLED = true;
  </script>
  {% endif %}
  <script>
    window.setTimeout(function () {
      if (!window.__FJKER_MATH_READY) {
        window.__FJKER_MATH_ERROR = window.__FJKER_MATH_ERROR || "MathJax did not finish rendering within 12000ms";
        window.__FJKER_MATH_DISABLED = true;
      }
    }, 12000);
  </script>
  {% endif %}
</body>
</html>
